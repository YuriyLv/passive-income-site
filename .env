# Конфігурація змінних середовища для індексаційних перевірок
# Згенеровано автоматично у рамках запуску ручного конфігурування доступу.
# Не додавайте .env у Git.

# Google Search Console
# Шлях до JSON-файлу ключа сервісного акаунта
GSC_KEY_PATH=
# URL сайту. Залишайте canonical як у статтях.
GSC_SITE_URL="https://biztoolinsight.com.ua/"

# Bing Webmaster
# API-ключ для Bing Webmaster
BING_WEBMASTER_API_KEY=
# URL сайту. Залишайте canonical як у статтях.
BING_SITE_URL="https://biztoolinsight.com.ua/"
