# Конфігурація змінних середовища для індексаційних перевірок.
# Копіюйте цей файл у .env, вкажіть реальні значення та збережіть локально.
# Не додавайте .env у Git-репозиторій.
#
# Цей файл синхронізовано з `scripts/indexing-check.sh`:
# - використовуються тільки змінні, які скрипт читає без зайвих аліасів;
# - `GSC_KEY_PATH` обов'язковий для Google;
# - `BING_WEBMASTER_API_KEY` обов'язковий для Bing.

# ===========================
# Google Search Console
# ===========================
# Шлях до JSON ключа сервісного облікового запису.
GSC_KEY_PATH=
# Приклад значення
# GSC_KEY_PATH_EXAMPLE=keys/gsc-service-account.json

# URL сайту для перевірки. Залишайте canonical домен як у статтях.
GSC_SITE_URL=
# Приклад значення
# GSC_SITE_URL_EXAMPLE=https://biztoolinsight.com.ua/

# Необов'язковий псевдонім заглушки: скрипт його тільки відтворює,
# реальна перевірка йде через обліковий запис за `GSC_KEY_PATH`.
# GSC_API_KEY=***
# GSC_API_KEY_EXAMPLE=***
# ===========================
# Bing Webmaster
# ===========================
# API-ключ для Bing Webmaster.
BING_WEBMASTER_API_KEY=
# Приклад значення
# BING_WEBMASTER_API_KEY_EXAMPLE=

# URL сайту для перевірки. Залишайте canonical домен як у статтях.
BING_SITE_URL=
# Приклад значення
# BING_SITE_URL_EXAMPLE=https://biztoolinsight.com.ua/
